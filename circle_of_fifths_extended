const PIANO_NOTES=[
  {note:'C',midi:48,black:false},{note:'C#',midi:49,black:true},{note:'D',midi:50,black:false},
  {note:'D#',midi:51,black:true},{note:'E',midi:52,black:false},{note:'F',midi:53,black:false},
  {note:'F#',midi:54,black:true},{note:'G',midi:55,black:false},{note:'G#',midi:56,black:true},
  {note:'A',midi:57,black:false},{note:'A#',midi:58,black:true},{note:'B',midi:59,black:false},
  {note:'C',midi:60,black:false},{note:'C#',midi:61,black:true},{note:'D',midi:62,black:false},
  {note:'D#',midi:63,black:true},{note:'E',midi:64,black:false},{note:'F',midi:65,black:false},
  {note:'F#',midi:66,black:true},{note:'G',midi:67,black:false},{note:'G#',midi:68,black:true},
  {note:'A',midi:69,black:false},{note:'A#',midi:70,black:true},{note:'B',midi:71,black:false}
];
const PIANO_DISPLAY={'C':'C','C#':'C♯','D':'D','D#':'D♯','E':'E','F':'F','F#':'F♯','G':'G','G#':'G♯','A':'A','A#':'A♯','B':'B'};
let pianoKeys=[];

function buildPiano(){
  const wrap=document.getElementById('piano-wrap');wrap.innerHTML='';pianoKeys=[];
  const whites=PIANO_NOTES.filter(n=>!n.black),wCount=whites.length;
  const totalW=Math.min(560,window.innerWidth-32);
  const ww=Math.floor(totalW/wCount);
  wrap.style.width=ww*wCount+'px';
  let wIdx=0;
  // Place white keys
  PIANO_NOTES.forEach((n,i)=>{
    if(n.black)return;
    const key=document.createElement('div');key.className='pk-white';
    key.style.left=wIdx*ww+'px';key.style.width=(ww-1)+'px';
    key.innerHTML=`<span class="pk-lbl">${PIANO_DISPLAY[n.note]}</span>`;
    const freq=440*Math.pow(2,(n.midi-69)/12);
    key.addEventListener('mousedown',e=>{e.preventDefault();stopAll();playNoteAt(freq,getAC().currentTime,.8);litSingle(key,600);});
    key.addEventListener('touchstart',e=>{e.preventDefault();stopAll();playNoteAt(freq,getAC().currentTime,.8);litSingle(key,600);},{passive:false});
    key.dataset.pc=n.midi%12;key.dataset.idx=i;
    wrap.appendChild(key);pianoKeys.push({el:key,pc:n.midi%12,midi:n.midi,note:n.note,black:false});
    wIdx++;
  });
  // Place black keys
  wIdx=0;
  const blackOffsets=[0.65,1.65,null,3.6,4.63,5.65,null]; // relative to white key index within octave
  PIANO_NOTES.forEach((n,i)=>{
    if(!n.black)return;
    const octave=Math.floor(i/12);
    const noteInOct=i%12;
    const blackMap={1:0,3:1,6:3,8:4,10:5};
    const bIdx=blackMap[noteInOct];
    if(bIdx===undefined)return;
    const bw=Math.floor(ww*.58);
    const xOff=Math.floor((blackOffsets[bIdx]+octave*7)*ww - bw/2);
    const key=document.createElement('div');key.className='pk-black';
    key.style.left=xOff+'px';key.style.width=bw+'px';
    key.innerHTML=`<span class="pk-lbl">${PIANO_DISPLAY[n.note]}</span>`;
    const freq=440*Math.pow(2,(n.midi-69)/12);
    key.addEventListener('mousedown',e=>{e.preventDefault();e.stopPropagation();stopAll();playNoteAt(freq,getAC().currentTime,.8);litSingle(key,600);});
    key.addEventListener('touchstart',e=>{e.preventDefault();e.stopPropagation();stopAll();playNoteAt(freq,getAC().currentTime,.8);litSingle(key,600);},{passive:false});
    key.dataset.pc=n.midi%12;key.dataset.idx=i;
    wrap.appendChild(key);pianoKeys.push({el:key,pc:n.midi%12,midi:n.midi,note:n.note,black:true});
  });
}

function updatePianoHighlight(semisArr,rootPC,quality){
  pianoKeys.forEach(k=>{
    k.el.classList.remove('hl','hl-major','hl-minor','hl-root');
    k.el.querySelector('.pk-lbl').textContent=PIANO_DISPLAY[k.note];
  });
  if(!semisArr||!semisArr.length)return;
  const pcs=semisArr.map(s=>(rootPC+s)%12);
  pianoKeys.forEach(k=>{
    if(pcs.includes(k.pc)){
      if(k.pc===rootPC)k.el.classList.add('hl-root');
      else if(quality==='major')k.el.classList.add('hl-major');
      else if(quality==='minor')k.el.classList.add('hl-minor');
      else k.el.classList.add('hl');
      // Show interval label
      const idx=pcs.indexOf(k.pc);
      const ivlNames=['R','♭2','2','♭3','3','4','♯4','5','♭6','6','♭7','7'];
      const semi=semisArr[idx]%12;
      k.el.querySelector('.pk-lbl').textContent=PIANO_DISPLAY[k.note]+' '+ivlNames[semi];
    }
  });
}

function pianoFromChord(chordName){
