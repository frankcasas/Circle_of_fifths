// ── PROGRESSION NOTATION (Grand Staff) ────────────────────────────────────
function renderProgNotation(){
  const el=document.getElementById('notation-prog');
  el.innerHTML='';
  if(!progression.length){el.innerHTML='<div class="not-empty">Add chords to see notation</div>';return;}
  const VF=Vex.Flow;
  const useFlats=keyUsesFlats();
  const voicings=computeVoicings();
  const n=progression.length;

  const chordW=Math.max(70,Math.min(110,540/n));
  const clefW=45;
  const totalW=Math.max(300,clefW+chordW*n+10);
  const staveW=totalW-20;

  const renderer=new VF.Renderer(el,VF.Renderer.Backends.SVG);
  renderer.resize(totalW,210);
  const ctx=renderer.getContext();
  ctx.setFont('Arial',10);
  ctx.scale(0.95,0.95);

  const treble=new VF.Stave(10,15,staveW);
  treble.addClef('treble');
  treble.setContext(ctx).draw();

  const bass=new VF.Stave(10,105,staveW);
  bass.addClef('bass');
  bass.setContext(ctx).draw();

  // Brace connector
  const brace=new VF.StaveConnector(treble,bass);
  brace.setType(VF.StaveConnector.type.BRACE);
  brace.setContext(ctx).draw();
  const line=new VF.StaveConnector(treble,bass);
  line.setType(VF.StaveConnector.type.SINGLE_LEFT);
  line.setContext(ctx).draw();

  const trebleNotes=[], bassNotes=[];

  voicings.forEach((v,i)=>{
    const p=progression[i];
    const midiNotes=v.midi.slice().sort((a,b)=>a-b);
    const tKeys=[],bKeys=[],tAcc=[],bAcc=[];

    midiNotes.forEach(m=>{
      const vn=midiToVex(m,useFlats);
      if(m>=60){tAcc.push(vn.acc);tKeys.push(vn.key);}
      else{bAcc.push(vn.acc);bKeys.push(vn.key);}
    });

    // Treble voice
    if(tKeys.length){
      const note=new VF.StaveNote({clef:'treble',keys:tKeys,duration:'w'});
      tAcc.forEach((a,j)=>{if(a)note.addAccidental(j,new VF.Accidental(a));});
      trebleNotes.push(note);
    }else{
      trebleNotes.push(new VF.StaveNote({clef:'treble',keys:['b/4'],duration:'wr'}));
    }

    // Bass voice
    if(bKeys.length){
      const note=new VF.StaveNote({clef:'bass',keys:bKeys,duration:'w'});
      bAcc.forEach((a,j)=>{if(a)note.addAccidental(j,new VF.Accidental(a));});
      bassNotes.push(note);
    }else{
      bassNotes.push(new VF.StaveNote({clef:'bass',keys:['d/3'],duration:'wr'}));
    }
  });

  try{
    const tVoice=new VF.Voice({num_beats:n*4,beat_value:4}).setStrict(false);
    tVoice.addTickables(trebleNotes);
    const bVoice=new VF.Voice({num_beats:n*4,beat_value:4}).setStrict(false);
    bVoice.addTickables(bassNotes);
    new VF.Formatter().joinVoices([tVoice]).joinVoices([bVoice]).format([tVoice,bVoice],staveW-clefW-10);
    tVoice.draw(ctx,treble);
    bVoice.draw(ctx,bass);

    // Chord labels above treble staff
    voicings.forEach((v,i)=>{
      const p=progression[i];
      const dispName=(progExtLevel===0&&p.extOverride===null)?p.chord:resolveChordName(p,progExtLevel);
      const x=trebleNotes[i].getAbsoluteX();
      ctx.fillStyle='#8888cc';
      ctx.font='bold 11px system-ui,sans-serif';
      ctx.fillText(dispName,x,12);
    });
  }catch(e){console.warn('Notation render error:',e);}
}

// ── SCALE NOTATION (Treble Staff) ─────────────────────────────────────────
function renderScaleNotation(){
  const el=document.getElementById('notation-scale');
  el.innerHTML='';
  if(selKey===null){el.innerHTML='<div class="not-empty">Select a key to see scale notation</div>';return;}
  const VF=Vex.Flow;
  const useFlats=keyUsesFlats();

  // Determine which scale to show: mode scale or pentatonic/blues
  const mr=typeof getModeRoot==='function'?getModeRoot():null;
  if(!mr){el.innerHTML='<div class="not-empty">Select a key</div>';return;}
  const mdata=MDATA[mode];
  const semis=mdata.semis[selMode];
  const rootClean=mr.clean;
  const baseOct=4;

  const notes=[];
  semis.forEach((s,i)=>{
    const midi=semiToMidi(rootClean,s,baseOct);
    const vn=midiToVex(midi,useFlats);
    const note=new VF.StaveNote({clef:'treble',keys:[vn.key],duration:'q'});
    if(vn.acc)note.addAccidental(0,new VF.Accidental(vn.acc));
    notes.push(note);
  });

  const totalW=Math.max(400,notes.length*52+60);
  const renderer=new VF.Renderer(el,VF.Renderer.Backends.SVG);
  renderer.resize(totalW,120);
  const ctx=renderer.getContext();

  const stave=new VF.Stave(10,10,totalW-20);
  stave.addClef('treble');
  stave.setContext(ctx).draw();

  try{
    const voice=new VF.Voice({num_beats:notes.length,beat_value:4}).setStrict(false);
    voice.addTickables(notes);
    new VF.Formatter().joinVoices([voice]).format([voice],totalW-80);
    voice.draw(ctx,stave);

    // Label
    ctx.fillStyle='#8888cc';
    ctx.font='bold 11px system-ui,sans-serif';
    ctx.fillText(mr.note+' '+mdata.names[selMode],totalW-140,20);
  }catch(e){console.warn('Scale notation error:',e);}

  // Also render extra scale (pentatonic/blues) below if available
  if(typeof EXTRA_SCALES!=='undefined'&&typeof curExtraScale!=='undefined'){
    const sc=EXTRA_SCALES[curExtraScale];
    const eNotes=[];
    sc.semis.forEach(s=>{
      const midi=semiToMidi(mr.clean,s,baseOct);
      const vn=midiToVex(midi,useFlats);
      const note=new VF.StaveNote({clef:'treble',keys:[vn.key],duration:'q'});
      if(vn.acc)note.addAccidental(0,new VF.Accidental(vn.acc));
      eNotes.push(note);
    });
    const eW=Math.max(350,eNotes.length*52+60);
    const container=document.createElement('div');
    container.style.cssText='margin-top:4px;border-top:1px solid #2a2a3a;padding-top:4px';
    el.appendChild(container);
    const eRenderer=new VF.Renderer(container,VF.Renderer.Backends.SVG);
    eRenderer.resize(eW,120);
    const eCtx=eRenderer.getContext();
    const eStave=new VF.Stave(10,10,eW-20);
    eStave.addClef('treble');
    eStave.setContext(eCtx).draw();
    try{
      const eVoice=new VF.Voice({num_beats:eNotes.length,beat_value:4}).setStrict(false);
      eVoice.addTickables(eNotes);
      new VF.Formatter().joinVoices([eVoice]).format([eVoice],eW-80);
      eVoice.draw(eCtx,eStave);
      eCtx.fillStyle='#7AB440';
      eCtx.font='bold 10px system-ui,sans-serif';
      eCtx.fillText(mr.note+' '+sc.name,eW-150,20);
    }catch(e){console.warn('Extra scale notation error:',e);}
  }
}

// ── CHORD EXPLORER NOTATION (Treble Staff) ────────────────────────────────
function renderExplNotation(){
  const el=document.getElementById('notation-expl');
  el.innerHTML='';
  if(!exState||!exState.root){el.innerHTML='<div class="not-empty">Open a chord in the explorer</div>';return;}
  const VF=Vex.Flow;
  const useFlats=keyUsesFlats();
  const{root,rootFreq,quality,extIdx,inv}=exState;
  const defs=EXT_DEFS[quality]||EXT_DEFS.major;
  const suffs=EXT_SUFFIX[quality]||EXT_SUFFIX.major;
  const safeExt=Math.min(extIdx,defs.length-1);
  const def=defs[safeExt];
  const invSemis=getInvSemis(def.semis,inv);
  const displayRoot=root.replace('#','♯').replace('b','♭');
  const suff=suffs[safeExt]||'';
  const baseOct=4;

  // Build chord notes
  const keys=[],accs=[];
  invSemis.forEach(s=>{
    const midi=semiToMidi(root,s,baseOct);
    const vn=midiToVex(midi,useFlats);
    keys.push(vn.key);
    accs.push(vn.acc);
  });

  const totalW=240;
  const renderer=new VF.Renderer(el,VF.Renderer.Backends.SVG);
  renderer.resize(totalW,140);
  const ctx=renderer.getContext();

  const stave=new VF.Stave(10,15,totalW-20);
  stave.addClef('treble');
  stave.setContext(ctx).draw();

  try{
    const note=new VF.StaveNote({clef:'treble',keys:keys,duration:'w'});
    accs.forEach((a,j)=>{if(a)note.addAccidental(j,new VF.Accidental(a));});
    const voice=new VF.Voice({num_beats:4,beat_value:4}).setStrict(false);
    voice.addTickables([note]);
    new VF.Formatter().joinVoices([voice]).format([voice],totalW-80);
    voice.draw(ctx,stave);
    ctx.fillStyle='#8888cc';
    ctx.font='bold 12px system-ui,sans-serif';
    ctx.fillText(displayRoot+suff,note.getAbsoluteX(),12);
  }catch(e){console.warn('Explorer notation error:',e);}
}

draw();
renderProgression();
</script>
