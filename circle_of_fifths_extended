// ── CHORD PROGRESSION BUILDER ────────────────────────────────────────────────
let progression=[];  // [{degIdx, chord, deg, quality}]
let progDragIdx=-1;
let progExtLevel=0;  // 0=triad, 1=7th, 2=9th, 3=11th, 4=13th
let progVoiceLead=false;

const PROG_PRESETS={
  'I–V–vi–IV':[0,4,5,3],
  'ii–V–I':[1,4,0],
  'I–vi–IV–V':[0,5,3,4],
  'I–IV–V–I':[0,3,4,0],
  'vi–IV–I–V':[5,3,0,4],
  'I–V–vi–iii–IV':[0,4,5,2,3],
  'ii–V–I–vi':[1,4,0,5],
  'I–IV–vi–V':[0,3,5,4],
  '12-Bar Blues':[0,0,0,0,3,3,0,0,4,3,0,4],
  '8-Bar Blues':[0,4,3,3,0,4,0,4],
  'Blues Turn.':[0,3,0,4],
  'Jazz Blues':[0,3,0,0,3,3,0,5,1,4,0,4],
};

// ── EXTENSION LEVEL MAPPING ─────────────────────────────────────────────────
// Maps (quality, degIdx, extLevel) → index into EXT_DEFS[quality]
// Smart defaults: ii→m7, V→dom7, I→maj7, vii°→ø7, etc.
function getExtDefIdx(quality,degIdx,level){
  if(level===0)return 0; // triad
  const isDominant=degIdx===4; // 5th degree = dominant
  const map={
    major:  isDominant?[0,1,3,5,7]:[0,2,4,6,8],  // Dom vs Maj
    minor:  [0,1,3,5,6],   // m7, m9, m11, m13
    dim:    [0,1,3,4,4],   // ø7, ø9, ø11
    aug:    [0,1,3,3,3],   // +7, +9
  };
  const arr=map[quality]||map.major;
  const defs=EXT_DEFS[quality]||EXT_DEFS.major;
  return Math.min(arr[Math.min(level,arr.length-1)],defs.length-1);
}

// Smart default: given a chord's function, return recommended EXT_DEFS index
// This goes beyond the basic level mapping with jazz-aware choices
const SMART_DEFAULTS={
  // For natural major: [triad, 7th, 9th, 11th, 13th] per degree
  natural:{
    major:{ // I, IV
      0:[0,2,4,6,8],  // I: maj7, maj9, maj11, maj13
      3:[0,2,4,6,8],  // IV: maj7, maj9, maj11, maj13
      4:[0,1,3,5,7],  // V: dom7, dom9, dom11, dom13
    },
    minor:{ // ii, iii, vi
      1:[0,1,3,5,6],  // ii: m7, m9, m11, m13
      2:[0,1,3,5,6],  // iii: m7, m9, m11, m13
      5:[0,1,3,5,6],  // vi: m7, m9, m11, m13
    },
    dim:{ 6:[0,1,3,4,4] }, // vii°: ø7, ø9, ø11
  },
};

// Resolve the effective extension index for a progression chord
// p = progression item, globalLevel = progExtLevel
function resolveChordExt(p,globalLevel){
  if(p.extOverride!==null&&p.extOverride!==undefined) return p.extOverride;
  return getExtDefIdx(p.quality,p.degIdx,globalLevel);
}

// Resolve effective semitones for a progression chord
function resolveChordSemis(p,globalLevel){
  const extIdx=resolveChordExt(p,globalLevel);
  const defs=EXT_DEFS[p.quality]||EXT_DEFS.major;
  return defs[Math.min(extIdx,defs.length-1)].semis;
}

// Get display name for a progression chord with overrides
function resolveChordName(p,globalLevel){
  const extIdx=resolveChordExt(p,globalLevel);
  const suffs=EXT_SUFFIX[p.quality]||EXT_SUFFIX.major;
  const dispRoot=rootStr(p.chord).replace('#','♯').replace(/b(?!$)/g,'♭');
  return dispRoot+(suffs[extIdx]||'');
}

// Get the display name for a chord at a given extension level
function getExtChordName(rootDisplay,quality,degIdx,level){
  const extIdx=getExtDefIdx(quality,degIdx,level);
  const suffs=EXT_SUFFIX[quality]||EXT_SUFFIX.major;
  return rootDisplay+(suffs[extIdx]||'');
}

// Get semitones for a chord at a given extension level
function getExtSemis(quality,degIdx,level){
  const extIdx=getExtDefIdx(quality,degIdx,level);
  const defs=EXT_DEFS[quality]||EXT_DEFS.major;
  return defs[Math.min(extIdx,defs.length-1)].semis;
}

// ── VOICE LEADING ENGINE ─────────────────────────────────────────────────────
// Given an array of semitone offsets (from root), root MIDI pitch, and inversion index,
// return array of absolute MIDI pitches in that voicing.
function voicingToMidi(semis,rootMidi,inv){
  const invSemis=getInvSemis(semis,inv);
  return invSemis.map(s=>rootMidi+s);
}

// Score how far apart two voicings are (lower = smoother)
function voiceDistance(midiA,midiB){
  // Sum of minimum distances from each note in B to nearest note in A
  let total=0;
  for(const b of midiB){
    let minD=999;
    for(const a of midiA) minD=Math.min(minD,Math.abs(b-a));
    total+=minD;
  }
  // Also penalize large overall register shifts
  const avgA=midiA.reduce((s,v)=>s+v,0)/midiA.length;
  const avgB=midiB.reduce((s,v)=>s+v,0)/midiB.length;
  total+=Math.abs(avgA-avgB)*0.5;
  return total;
}

// Find the best inversion for chord B given chord A's voicing
function bestInversion(prevMidi,semisB,rootMidiB){
  const n=semisB.length;
  const maxInv=Math.min(n-1,3);
  let bestInv=0,bestDist=Infinity;
  for(let inv=0;inv<=maxInv;inv++){
    const midi=voicingToMidi(semisB,rootMidiB,inv);
    const d=voiceDistance(prevMidi,midi);
    if(d<bestDist){bestDist=d;bestInv=inv;}
  }
  return bestInv;
}

// Compute voice-led voicings for the entire progression
function computeVoicings(){
  if(!progression.length)return[];
  const voicings=[];
  for(let i=0;i<progression.length;i++){
    const p=progression[i];
    const r=rootStr(p.chord);
    const rootMidi=48+(RMIDI[r]||0); // octave 3
    const semis=resolveChordSemis(p,progExtLevel);
    const hasPinnedInv=p.invOverride!==null&&p.invOverride!==undefined;
    
    if(hasPinnedInv){
      // Use the pinned inversion
      const inv=p.invOverride;
      voicings.push({semis:getInvSemis(semis,inv),inv,midi:voicingToMidi(semis,rootMidi,inv),rootFreq:NF[r]||261.63});
    } else if(i===0||!progVoiceLead){
      voicings.push({semis:semis.slice(),inv:0,midi:voicingToMidi(semis,rootMidi,0),rootFreq:NF[r]||261.63});
    } else {
      const inv=bestInversion(voicings[i-1].midi,semis,rootMidi);
      voicings.push({semis:getInvSemis(semis,inv),inv,midi:voicingToMidi(semis,rootMidi,inv),rootFreq:NF[r]||261.63});
    }
  }
  return voicings;
}

// ── REBUILD FROM CURRENT KEY/MODE ────────────────────────────────────────────
function getActiveChords(){
  if(selKey===null)return{chords:[],degs:[]};
  const modeChords=getModeChords(selKey,selMode);
  const modeDegs=MDATA[mode].degs[selMode];
  return{chords:modeChords,degs:modeDegs};
}

function rebuildProgChords(){
  if(selKey===null)return;
  const{chords,degs}=getActiveChords();
  progression.forEach(p=>{
    const di=p.degIdx;
    if(di>=0&&di<7){
      p.chord=chords[di];
      p.deg=degs[di];
      p.quality=qualStr(p.chord);
    }
  });
  renderProgression();
}

// ── PRESETS ──────────────────────────────────────────────────────────────────
function buildPresets(){
  const el=document.getElementById('prog-presets');el.innerHTML='';
  Object.keys(PROG_PRESETS).forEach(name=>{
    const btn=document.createElement('button');btn.className='preset-btn';btn.textContent=name;
    btn.addEventListener('click',()=>{
      if(selKey===null)return;
      const{chords,degs}=getActiveChords();
      const indices=PROG_PRESETS[name];
      progression=indices.map(i=>({
        degIdx:i, chord:chords[i], deg:degs[i], quality:qualStr(chords[i]), extOverride:null, invOverride:null
      }));
      renderProgression();
    });
    el.appendChild(btn);
  });
}

function addToProgression(chord,deg){
  const{chords}=getActiveChords();
  let degIdx=chords.indexOf(chord);
  if(degIdx<0){
    const md=DATA[mode];
    if(selKey!==null) degIdx=md.rows[selKey].indexOf(chord);
  }
  progression.push({degIdx,chord,deg:deg||'',quality:qualStr(chord),extOverride:null,invOverride:null});
  renderProgression();
}

function renderProgression(){
  const strip=document.getElementById('prog-strip');strip.innerHTML='';
  strip.classList.toggle('empty',progression.length===0);
  document.getElementById('prog-play').disabled=progression.length===0;
  const _expHas=progression.length>0;
  if(document.getElementById('exp-text')){document.getElementById('exp-text').disabled=!_expHas;document.getElementById('exp-midi').disabled=!_expHas;document.getElementById('exp-wav').disabled=!_expHas;}

  const voicings=computeVoicings();
  const invNames=['root','1st','2nd','3rd'];

  // Build info string with extended chord names
  const infoNames=progression.map(p=>{
    if(progExtLevel===0&&p.extOverride===null)return p.deg||p.chord;
    return resolveChordName(p,progExtLevel);
  });
  document.getElementById('prog-info').textContent=progression.length?
    progression.length+' chord'+(progression.length>1?'s':'')+' · '+infoNames.join(' → '):'';

  progression.forEach((p,i)=>{
    const card=document.createElement('div');
    card.className=`prog-card ${p.quality}`;
    card.draggable=true;

    // Display name respects per-chord override or global level
    const dispName=(progExtLevel===0&&p.extOverride===null)?p.chord:resolveChordName(p,progExtLevel);
    const v=voicings[i];
    const invLabel=v&&v.inv>0?invNames[v.inv]:'';
    const hasCustom=p.extOverride!==null||p.invOverride!==null;
    const customTag=hasCustom?'<span class="pc-custom">✦</span>':'';

    card.innerHTML=`<span class="pc-deg">${p.deg}</span><span class="pc-nm">${dispName}</span><span class="pc-ql">${QL[p.quality]||''}</span>${invLabel?'<span class="pc-inv">'+invLabel+'</span>':''}${customTag}<span class="pc-ed" title="Edit voicing">✎</span><span class="pc-rm" title="Remove">×</span>`;

    // Play on click
    card.addEventListener('click',e=>{
      if(e.target.classList.contains('pc-rm')||e.target.classList.contains('pc-ed'))return;
      stopAll();
      const v=voicings[i];
      if(v){playExtChord(v.rootFreq,v.semis);}
      else{playChordAt(p.chord,getAC().currentTime);}
      litSingle(card,1800);
      const r=rootStr(p.chord);
      const rpc=RMIDI[r]!==undefined?RMIDI[r]:0;
      const extSemis=resolveChordSemis(p,progExtLevel);
      updatePianoHighlight(extSemis,rpc,p.quality);
      showPiano();
      document.getElementById('piano-context').textContent=dispName+(v&&v.inv>0?' — '+invNames[v.inv]+' inv':'');
    });

    // Edit button
    card.querySelector('.pc-ed').addEventListener('click',e=>{
      e.stopPropagation();
      openChordEditor(i);
    });

    // Remove
    card.querySelector('.pc-rm').addEventListener('click',e=>{
      e.stopPropagation();progression.splice(i,1);closeChordEditor();renderProgression();
    });

    // Drag & drop reordering
    card.addEventListener('dragstart',e=>{progDragIdx=i;card.classList.add('dragging');e.dataTransfer.effectAllowed='move';});
    card.addEventListener('dragend',()=>{card.classList.remove('dragging');progDragIdx=-1;document.querySelectorAll('.prog-card').forEach(c=>c.classList.remove('drag-over'));});
    card.addEventListener('dragover',e=>{e.preventDefault();e.dataTransfer.dropEffect='move';document.querySelectorAll('.prog-card').forEach(c=>c.classList.remove('drag-over'));if(i!==progDragIdx)card.classList.add('drag-over');});
    card.addEventListener('drop',e=>{e.preventDefault();if(progDragIdx<0||progDragIdx===i)return;const item=progression.splice(progDragIdx,1)[0];progression.splice(i,0,item);renderProgression();});

    strip.appendChild(card);
  });

  // Refresh editor if open
  if(editingIdx>=0&&editingIdx<progression.length) refreshChordEditor();
  if(typeof updateAllNotation==='function')updateAllNotation();
}

// ── PLAY PROGRESSION ─────────────────────────────────────────────────────────
document.getElementById('prog-play').onclick=function(){
  if(!progression.length)return;
  stopAll();seqRunning=true;
  const bpm=+document.getElementById('prog-bpm').value;
  const beatDur=60/bpm;
  const chordDur=beatDur*2;
  const a=getAC();
  const voicings=computeVoicings();

  progression.forEach((p,i)=>{
    const v=voicings[i];
    const when=a.currentTime+i*chordDur;
    if(v){playExtChord(v.rootFreq,v.semis,chordDur*.9,when);}
    else{playChordAt(p.chord,when,chordDur*.9);}

    seqCBs.push(setTimeout(()=>{
      if(!seqRunning)return;
      document.querySelectorAll('.prog-card').forEach((c,j)=>c.classList.toggle('lit',j===i));
      const r=rootStr(p.chord);
      const rpc=RMIDI[r]!==undefined?RMIDI[r]:0;
      const semis=resolveChordSemis(p,progExtLevel);
      updatePianoHighlight(semis,rpc,p.quality);
      showPiano();
      const dispName=(progExtLevel===0&&p.extOverride===null)?p.chord:resolveChordName(p,progExtLevel);
      const invLabel=v&&v.inv>0?['','1st inv','2nd inv','3rd inv'][v.inv]:'';
      document.getElementById('cinfo').textContent=`${dispName} · ${p.deg}${invLabel?' · '+invLabel:''}`;
      document.getElementById('piano-context').textContent=dispName+(invLabel?' — '+invLabel:'');
      if(i===progression.length-1){
        seqCBs.push(setTimeout(()=>{
