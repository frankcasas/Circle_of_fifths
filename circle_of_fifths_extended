
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:transparent;display:flex;flex-direction:column;align-items:center;padding:10px 0;font-family:system-ui,-apple-system,sans-serif;color:#ddd}
#tabs{display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap;justify-content:center}
#tabs button{font-size:12px;padding:5px 15px;border:1px solid #555;border-radius:20px;background:transparent;color:#888;cursor:pointer;transition:all .15s}
#tabs button.on{background:#4A44AA;color:#fff;border-color:#4A44AA;font-weight:500}
#qrow{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:6px;font-size:11px;color:#888}
.qtag{display:flex;align-items:center;gap:4px}.qdot{width:10px;height:10px;border-radius:2px}
canvas{display:block;cursor:default}
#cinfo{font-size:12px;color:#777;min-height:16px;margin:4px 0 2px;text-align:center}
#bottom{width:min(600px,96vw);margin-top:10px;display:none;flex-direction:column;gap:0}
.section{padding:10px 0;border-top:1px solid #2a2a3a}
.section:first-child{border-top:none;padding-top:0}
.sec-title{font-size:10px;font-weight:600;color:#555;letter-spacing:.07em;text-transform:uppercase;margin-bottom:7px;text-align:center}
.sub-label{font-size:9px;font-weight:600;color:#555;letter-spacing:.07em;text-transform:uppercase;margin:8px 0 5px;text-align:center}
.chord-row{display:flex;gap:4px;justify-content:center;flex-wrap:wrap}
.chord-btn{display:flex;flex-direction:column;align-items:center;gap:1px;padding:7px 7px 5px;border-radius:8px;cursor:pointer;border:1px solid transparent;min-width:50px;transition:all .1s}
.chord-btn:hover{filter:brightness(1.2)}.chord-btn.lit{transform:scale(.93);filter:brightness(1.4)}
.chord-btn .cb-deg{font-size:9px;font-weight:600;opacity:.75}.chord-btn .cb-nm{font-size:13px;font-weight:600}.chord-btn .cb-ql{font-size:8px;opacity:.6;text-transform:capitalize}
.chord-btn.major{background:#1F3D5C;border-color:#3B6FA0;color:#B5D4F8}
.chord-btn.minor{background:#2A1F5C;border-color:#5B4FA0;color:#D4D0F8}
.chord-btn.aug{background:#4A2A05;border-color:#A06020;color:#F8DEAD}
.chord-btn.dim{background:#0F3A0F;border-color:#3A7A3A;color:#C0EAC0}
#mode-strip{display:flex;gap:4px;justify-content:center;flex-wrap:wrap;margin-bottom:8px}
.mode-pill{display:flex;flex-direction:column;align-items:center;gap:1px;padding:5px 7px;border-radius:7px;cursor:pointer;border:1px solid #3a3a4a;background:#181825;min-width:56px;transition:all .1s}
.mode-pill:hover{border-color:#6666aa;background:#22223a}.mode-pill.on{background:#3A3490;border-color:#7770DD}
.mode-pill .mp-dg{font-size:9px;color:#888;font-weight:600}.mode-pill.on .mp-dg{color:#bbb}
.mode-pill .mp-nm{font-size:8.5px;color:#aaa;font-weight:500;text-align:center;line-height:1.2}.mode-pill.on .mp-nm{color:#e8e4ff}
.mode-pill .mp-rt{font-size:8px;color:#555;margin-top:1px}.mode-pill.on .mp-rt{color:#8884cc}
#mode-detail{display:flex;flex-direction:column;gap:5px}
#mode-header{display:flex;align-items:baseline;justify-content:center;gap:8px;flex-wrap:wrap}
#mode-name{font-size:14px;font-weight:600;color:#c8c4ff}#mode-root-lbl{font-size:12px;color:#888}
#mode-intervals{display:flex;gap:3px;justify-content:center;flex-wrap:wrap}
.int-tag{font-size:9px;padding:2px 5px;border-radius:4px;background:#1e1e2e;border:1px solid #3a3a4a;color:#888;font-weight:500}
.int-tag.root{background:#3A3490;border-color:#7770DD;color:#e8e4ff}
.note-strip{display:flex;gap:3px;justify-content:center;flex-wrap:wrap}
.note-btn{display:flex;flex-direction:column;align-items:center;gap:2px;padding:7px 5px 5px;border-radius:7px;cursor:pointer;border:1px solid #3a3a4a;background:#181825;min-width:42px;transition:all .1s}
.note-btn:hover{border-color:#6666aa;background:#22223a}.note-btn.lit{background:#4A44AA;border-color:#8882ee;transform:scale(.94)}
.note-btn .nb-iv{font-size:9px;color:#888;font-weight:500}.note-btn .nb-nt{font-size:13px;font-weight:600;color:#e8e4ff}
.note-btn.lit .nb-iv,.note-btn.lit .nb-nt{color:#fff}
#playrow{display:flex;gap:5px;justify-content:center;flex-wrap:wrap;margin-top:2px}
#playrow button{font-size:11px;padding:4px 12px;border:1px solid #444;border-radius:6px;background:transparent;color:#aaa;cursor:pointer}
#playrow button:hover{background:#2a2a3a;color:#ddd}

/* ── CHORD EXPLORER ── */
#expl{width:min(600px,96vw);margin-top:0;display:none;flex-direction:column;gap:0;border-top:1px solid #3a3a4a;padding-top:10px}
#expl-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
#expl-cname{font-size:18px;font-weight:700;color:#e8e4ff;letter-spacing:.01em}
#expl-slash{font-size:14px;color:#888;margin-left:2px}
#expl-source{font-size:11px;color:#666}
#expl-close{background:none;border:none;color:#666;cursor:pointer;font-size:16px;padding:0 4px;line-height:1}
#expl-close:hover{color:#aaa}
.expl-row-label{font-size:9px;font-weight:600;color:#555;letter-spacing:.07em;text-transform:uppercase;margin:6px 0 4px}
#expl-ext{display:flex;gap:4px;flex-wrap:wrap}
.ext-chip{font-size:11px;padding:3px 9px;border-radius:5px;border:1px solid #3a3a4a;background:#181825;color:#888;cursor:pointer;transition:all .1s}
.ext-chip:hover{border-color:#6666aa;color:#ccc}.ext-chip.on{background:#3A3490;border-color:#7770DD;color:#e8e4ff;font-weight:500}
#expl-inv{display:flex;gap:4px;flex-wrap:wrap}
.inv-btn{font-size:11px;padding:3px 10px;border-radius:5px;border:1px solid #3a3a4a;background:#181825;color:#888;cursor:pointer;transition:all .1s}
.inv-btn:hover{border-color:#6666aa;color:#ccc}.inv-btn.on{background:#2A3A5C;border-color:#3B6FA0;color:#B5D4F8;font-weight:500}
#expl-notes{display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin:4px 0}
.expl-note{display:flex;flex-direction:column;align-items:center;gap:2px;padding:8px 7px 6px;border-radius:8px;cursor:pointer;border:1px solid #3a3a4a;background:#1a1a2e;min-width:46px;transition:all .1s}
.expl-note:hover{border-color:#6666aa;background:#22223a}.expl-note.lit{background:#4A44AA;border-color:#8882ee;transform:scale(.93)}
.expl-note.bass{background:#1a2a1a;border-color:#3A7A3A}.expl-note.bass:hover{background:#1e361e}
.expl-note.bass.lit{background:#3A7A3A}
.en-iv{font-size:9px;color:#888;font-weight:500}.en-nt{font-size:14px;font-weight:600;color:#e8e4ff}
.expl-note.bass .en-iv{color:#5A9A5A}.expl-note.bass .en-nt{color:#C0EAC0}
#expl-playrow{display:flex;gap:6px;align-items:center;margin-top:6px}
#expl-play{font-size:12px;padding:6px 18px;border:1px solid #4A44AA;border-radius:6px;background:#2A2460;color:#c8c4ff;cursor:pointer;font-weight:500}
#expl-play:hover{background:#3A3490;color:#e8e4ff}
#expl-voice-info{font-size:11px;color:#555;flex:1}

#snd{display:flex;gap:5px;flex-wrap:wrap;justify-content:center;margin-top:8px}
#snd button{font-size:11px;padding:4px 10px;border:1px solid #555;border-radius:6px;background:transparent;color:#888;cursor:pointer}
#snd button.on{background:#2a2a3a;color:#ddd;font-weight:500;border-color:#777}
#vrow{display:flex;align-items:center;gap:8px;font-size:12px;color:#888;margin-top:4px}

/* ── PIANO KEYBOARD ── */
#piano-section{width:min(600px,96vw);margin-top:14px;display:none;flex-direction:column;gap:6px}
#piano-label{font-size:10px;font-weight:600;color:#555;letter-spacing:.07em;text-transform:uppercase;text-align:center}
#piano-context{font-size:11px;color:#666;text-align:center;min-height:16px}
#piano-wrap{position:relative;height:120px;margin:0 auto;user-select:none;-webkit-user-select:none}
.pk-white{position:absolute;bottom:0;height:120px;background:#1a1a2e;border:1px solid #3a3a4a;border-radius:0 0 5px 5px;cursor:pointer;transition:background .08s,transform .08s;z-index:1}
.pk-white:hover{background:#22223a}
.pk-white.hl{background:#3A3490;border-color:#7770DD;box-shadow:0 0 12px rgba(74,68,170,.5)}
.pk-white.hl-major{background:#1F3D5C;border-color:#3B6FA0;box-shadow:0 0 10px rgba(59,111,160,.4)}
.pk-white.hl-minor{background:#2A1F5C;border-color:#5B4FA0;box-shadow:0 0 10px rgba(91,79,160,.4)}
.pk-white.hl-root{background:#4A44AA;border-color:#8882ee;box-shadow:0 0 14px rgba(74,68,170,.6)}
.pk-white.lit{background:#6A64CC !important;transform:scaleY(.97);transform-origin:top}
.pk-white .pk-lbl{position:absolute;bottom:5px;left:50%;transform:translateX(-50%);font-size:9px;color:#555;font-weight:500;pointer-events:none;white-space:nowrap}
.pk-white.hl .pk-lbl,.pk-white.hl-major .pk-lbl,.pk-white.hl-minor .pk-lbl,.pk-white.hl-root .pk-lbl{color:#c8c4ff}
.pk-black{position:absolute;top:0;height:74px;background:#0a0a14;border:1px solid #2a2a3a;border-radius:0 0 3px 3px;cursor:pointer;transition:background .08s,transform .08s;z-index:2}
.pk-black:hover{background:#1a1a2a}
.pk-black.hl{background:#2A2460;border-color:#5B54AA;box-shadow:0 0 10px rgba(74,68,170,.4)}
.pk-black.hl-major{background:#163050;border-color:#2A5580;box-shadow:0 0 8px rgba(59,111,160,.3)}
.pk-black.hl-minor{background:#1F1650;border-color:#3A3080;box-shadow:0 0 8px rgba(91,79,160,.3)}
.pk-black.hl-root{background:#3A3490;border-color:#6660BB;box-shadow:0 0 12px rgba(74,68,170,.5)}
.pk-black.lit{background:#5A54BB !important;transform:scaleY(.96);transform-origin:top}
.pk-black .pk-lbl{position:absolute;bottom:4px;left:50%;transform:translateX(-50%);font-size:7px;color:#444;font-weight:500;pointer-events:none;white-space:nowrap}
.pk-black.hl .pk-lbl,.pk-black.hl-major .pk-lbl,.pk-black.hl-minor .pk-lbl,.pk-black.hl-root .pk-lbl{color:#aaa8dd}

/* ── CHORD PROGRESSION BUILDER ── */
#prog-section{width:min(600px,96vw);margin-top:14px;display:flex;flex-direction:column;gap:8px;border-top:1px solid #2a2a3a;padding-top:12px}
#prog-header{display:flex;align-items:center;justify-content:space-between}
#prog-title{font-size:10px;font-weight:600;color:#555;letter-spacing:.07em;text-transform:uppercase}
#prog-actions{display:flex;gap:5px}
#prog-actions button{font-size:11px;padding:4px 10px;border:1px solid #444;border-radius:6px;background:transparent;color:#888;cursor:pointer;transition:all .1s}
#prog-actions button:hover{background:#2a2a3a;color:#ddd}
#prog-presets{display:flex;gap:4px;flex-wrap:wrap;justify-content:center}
.preset-btn{font-size:10px;padding:3px 8px;border-radius:4px;border:1px solid #333;background:transparent;color:#666;cursor:pointer;transition:all .1s}
.preset-btn:hover{border-color:#6666aa;color:#bbb;background:#1a1a2a}
#prog-strip{display:flex;gap:6px;flex-wrap:wrap;min-height:54px;padding:8px;border:1px dashed #2a2a3a;border-radius:10px;align-items:flex-start;position:relative}
#prog-strip.empty::after{content:'Click chords above to add them here';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:11px;color:#333;pointer-events:none}
.prog-card{display:flex;flex-direction:column;align-items:center;gap:2px;padding:8px 10px 6px;border-radius:8px;cursor:grab;min-width:52px;position:relative;transition:all .1s;user-select:none;-webkit-user-select:none}
.prog-card:active{cursor:grabbing;opacity:.8}
.prog-card.lit{transform:scale(.92);filter:brightness(1.5)}
.prog-card .pc-deg{font-size:8px;opacity:.65;font-weight:600}.prog-card .pc-nm{font-size:14px;font-weight:600}.prog-card .pc-ql{font-size:7px;opacity:.5;text-transform:capitalize}
.prog-card .pc-rm{position:absolute;top:-4px;right:-4px;width:16px;height:16px;border-radius:50%;background:#333;border:1px solid #555;color:#888;font-size:10px;line-height:14px;text-align:center;cursor:pointer;opacity:0;transition:opacity .15s}
.prog-card:hover .pc-rm{opacity:1}.prog-card .pc-rm:hover{background:#663;border-color:#aa6;color:#eeb}
.prog-card.major{background:#1F3D5C;border:1px solid #3B6FA0;color:#B5D4F8}
.prog-card.minor{background:#2A1F5C;border:1px solid #5B4FA0;color:#D4D0F8}
.prog-card.aug{background:#4A2A05;border:1px solid #A06020;color:#F8DEAD}
.prog-card.dim{background:#0F3A0F;border:1px solid #3A7A3A;color:#C0EAC0}
.prog-card.dragging{opacity:.4}
.prog-card.drag-over{transform:translateX(8px)}
#prog-playrow{display:flex;gap:6px;align-items:center;justify-content:center}
#prog-play{font-size:12px;padding:6px 18px;border:1px solid #4A44AA;border-radius:6px;background:#2A2460;color:#c8c4ff;cursor:pointer;font-weight:500}
#prog-play:hover{background:#3A3490;color:#e8e4ff}
#prog-play:disabled{opacity:.35;cursor:default}
#prog-tempo{display:flex;align-items:center;gap:6px;font-size:11px;color:#666}
#prog-tempo input{width:70px}
#prog-info{font-size:11px;color:#555;text-align:center}
#prog-opts{display:flex;gap:10px;flex-wrap:wrap;align-items:center;justify-content:center}
#prog-ext-row{display:flex;gap:3px;align-items:center}
#prog-ext-row .popt-label{font-size:9px;font-weight:600;color:#555;letter-spacing:.05em;text-transform:uppercase;margin-right:3px}
.pext-btn{font-size:10px;padding:2px 8px;border-radius:4px;border:1px solid #333;background:transparent;color:#666;cursor:pointer;transition:all .1s}
.pext-btn:hover{border-color:#6666aa;color:#bbb}.pext-btn.on{background:#3A3490;border-color:#7770DD;color:#e8e4ff;font-weight:500}
#prog-vl-wrap{display:flex;align-items:center;gap:5px}
#prog-vl-wrap .popt-label{font-size:9px;font-weight:600;color:#555;letter-spacing:.05em;text-transform:uppercase}
.vl-toggle{position:relative;width:34px;height:18px;border-radius:9px;background:#2a2a3a;border:1px solid #444;cursor:pointer;transition:all .15s}
.vl-toggle.on{background:#3A3490;border-color:#7770DD}
.vl-toggle::after{content:'';position:absolute;top:2px;left:2px;width:12px;height:12px;border-radius:50%;background:#666;transition:all .15s}
.vl-toggle.on::after{left:18px;background:#c8c4ff}
.prog-card .pc-inv{font-size:7px;color:rgba(255,255,255,.45);margin-top:1px;font-weight:500}
.prog-card .pc-ed{position:absolute;top:-4px;left:-4px;width:16px;height:16px;border-radius:50%;background:#333;border:1px solid #555;color:#888;font-size:8px;line-height:15px;text-align:center;cursor:pointer;opacity:0;transition:opacity .15s}
.prog-card:hover .pc-ed{opacity:1}.prog-card .pc-ed:hover{background:#336;border-color:#66a;color:#aaf}
.prog-card.editing{outline:2px solid #7770DD;outline-offset:1px}
.prog-card .pc-custom{font-size:6px;color:rgba(255,200,100,.7);font-weight:600;letter-spacing:.03em}

/* ── CHORD EDITOR PANEL ── */
#chord-editor{display:none;width:min(600px,96vw);padding:10px 12px;border:1px solid #3a3a5a;border-radius:10px;background:#16162a;margin-top:6px}
#chord-editor.open{display:flex;flex-direction:column;gap:8px}
#ce-header{display:flex;align-items:center;justify-content:space-between}
#ce-title{font-size:13px;font-weight:600;color:#c8c4ff}
#ce-close{background:none;border:none;color:#666;cursor:pointer;font-size:16px;padding:0 4px;line-height:1}
#ce-close:hover{color:#aaa}
.ce-row{display:flex;flex-direction:column;gap:4px}
.ce-row-label{font-size:9px;font-weight:600;color:#555;letter-spacing:.06em;text-transform:uppercase}
.ce-chips{display:flex;gap:3px;flex-wrap:wrap}
.ce-chip{font-size:10px;padding:3px 9px;border-radius:5px;border:1px solid #3a3a4a;background:#181825;color:#888;cursor:pointer;transition:all .1s}
.ce-chip:hover{border-color:#6666aa;color:#ccc}
.ce-chip.on{background:#3A3490;border-color:#7770DD;color:#e8e4ff;font-weight:500}
.ce-chip.auto{font-style:italic;color:#8888bb}
.ce-chip.auto.on{background:#2A3A5C;border-color:#3B6FA0;color:#B5D4F8}
#ce-preview{font-size:11px;color:#777;text-align:center;min-height:16px}
#ce-play{font-size:11px;padding:4px 14px;border:1px solid #4A44AA;border-radius:6px;background:#2A2460;color:#c8c4ff;cursor:pointer;font-weight:500;align-self:center}
#ce-play:hover{background:#3A3490;color:#e8e4ff}

/* ── EXTRA SCALES (Pentatonic / Blues) ── */
#extra-scales{width:min(600px,96vw);margin-top:0;display:none;flex-direction:column;gap:6px;padding-top:8px}
#extra-scales .sec-title{font-size:10px;font-weight:600;color:#555;letter-spacing:.07em;text-transform:uppercase;margin-bottom:5px;text-align:center}
#escale-tabs{display:flex;gap:4px;justify-content:center;flex-wrap:wrap}
.escale-tab{font-size:11px;padding:4px 12px;border-radius:6px;border:1px solid #3a3a4a;background:#181825;color:#888;cursor:pointer;transition:all .1s}
.escale-tab:hover{border-color:#6666aa;color:#ccc;background:#22223a}
.escale-tab.on{background:#3A3490;border-color:#7770DD;color:#e8e4ff;font-weight:500}
.escale-tab.rec{border-color:#5A7A3A;color:#aac888}
.escale-tab.rec.on{background:#2A4A20;border-color:#5A9A3A;color:#d0f0b0}
.escale-tab .rec-dot{display:inline-block;width:5px;height:5px;border-radius:50%;background:#7AB440;margin-left:4px;vertical-align:middle}
#escale-rec-hint{font-size:9px;color:#5A7A3A;text-align:center;min-height:12px;font-style:italic}
#escale-notes{display:flex;gap:3px;justify-content:center;flex-wrap:wrap;margin-top:4px}
#escale-intervals{display:flex;gap:3px;justify-content:center;flex-wrap:wrap;margin-top:2px}
#escale-playrow{display:flex;gap:6px;justify-content:center;margin-top:4px}
#escale-playrow button{font-size:11px;padding:4px 12px;border:1px solid #444;border-radius:6px;background:transparent;color:#aaa;cursor:pointer}
#escale-playrow button:hover{background:#2a2a3a;color:#ddd}
#escale-name{font-size:13px;font-weight:600;color:#c8c4ff;text-align:center;margin-bottom:2px}

/* ── EXPORT BUTTONS ── */
#export-row{display:flex;gap:5px;flex-wrap:wrap;justify-content:center;margin-top:4px}
#export-row button{font-size:11px;padding:5px 12px;border:1px solid #444;border-radius:6px;background:transparent;color:#888;cursor:pointer;transition:all .12s;display:flex;align-items:center;gap:4px}
#export-row button:hover{background:#2a2a3a;color:#ddd;border-color:#666}
#export-row button:disabled{opacity:.35;cursor:default}
#export-row button .exp-icon{font-size:13px}
#export-status{font-size:10px;color:#555;text-align:center;min-height:14px;margin-top:2px}

/* ── SHEET MUSIC NOTATION ── */
#notation-toggle{font-size:11px;padding:5px 14px;border:1px solid #444;border-radius:6px;background:transparent;color:#888;cursor:pointer;transition:all .12s;display:flex;align-items:center;gap:5px;margin:6px auto 0}
#notation-toggle:hover{background:#2a2a3a;color:#ddd;border-color:#666}
#notation-toggle.on{background:#2A2460;border-color:#4A44AA;color:#c8c4ff;font-weight:500}
#notation-section{width:min(620px,97vw);display:none;flex-direction:column;gap:10px;margin-top:8px;padding-top:10px;border-top:1px solid #2a2a3a}
.not-panel{display:flex;flex-direction:column;gap:4px}
.not-panel-title{font-size:9px;font-weight:600;color:#555;letter-spacing:.07em;text-transform:uppercase;text-align:center}
.not-container{overflow-x:auto;overflow-y:hidden;-webkit-overflow-scrolling:touch;border:1px solid #2a2a3a;border-radius:8px;background:#0e0e1a;padding:6px 4px}
.not-container svg{display:block}
.not-empty{font-size:11px;color:#444;text-align:center;padding:14px 10px;font-style:italic}
#notation-err{font-size:11px;color:#664;text-align:center;padding:10px;display:none}
</style>
</head>
<body>
<div id="tabs">
  <button class="on" data-m="natural">Natural Major</button>
  <button data-m="harmonic">Harmonic Minor</button>
  <button data-m="melodic">Melodic Minor</button>
</div>
<div id="qrow">
  <span class="qtag"><span class="qdot" style="background:#3B6FA0"></span>major</span>
  <span class="qtag"><span class="qdot" style="background:#5B4FA0"></span>minor</span>
  <span class="qtag"><span class="qdot" style="background:#A06020"></span>augmented</span>
  <span class="qtag"><span class="qdot" style="background:#3A7A3A"></span>diminished</span>
</div>
<canvas id="cv"></canvas>
<div id="cinfo">Click a key to explore chords &amp; modes</div>

<div id="bottom">
