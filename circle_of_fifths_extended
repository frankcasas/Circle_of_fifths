// ── EXPORT: MIDI ──────────────────────────────────────────────────────────
function buildMidiFile(prog,voicings,bpm){
  const ticksPerBeat=480;
  const chordTicks=ticksPerBeat*2;

  function varLen(v){
    const bytes=[];
    bytes.push(v&0x7F);
    while((v>>=7)>0){bytes.push((v&0x7F)|0x80);}
    return bytes.reverse();
  }
  function strBytes(s){return Array.from(s).map(c=>c.charCodeAt(0));}
  function int16(v){return[(v>>8)&0xFF,v&0xFF];}
  function int32(v){return[(v>>24)&0xFF,(v>>16)&0xFF,(v>>8)&0xFF,v&0xFF];}

  const events=[];
  const uspqn=Math.round(60000000/bpm);
  events.push([0,0xFF,0x51,0x03,(uspqn>>16)&0xFF,(uspqn>>8)&0xFF,uspqn&0xFF]);

  prog.forEach((p,i)=>{
    const v=voicings[i];
    const r=rootStr(p.chord);
    const rootMidi=48+(RMIDI[r]||0);
    const midiNotes=v?v.midi:voicingToMidi(resolveChordSemis(p,progExtLevel),rootMidi,0);
    midiNotes.forEach((n,j)=>{
      const clamped=Math.max(0,Math.min(127,n));
      events.push([j===0&&i===0?0:j===0?0:0, 0x90, clamped, 90]);
    });
    midiNotes.forEach((n,j)=>{
      const clamped=Math.max(0,Math.min(127,n));
      events.push([j===0?chordTicks:0, 0x80, clamped, 0]);
    });
  });

  events.push([0,0xFF,0x2F,0x00]);

  const trackBytes=[];
  events.forEach(ev=>{
    const delta=ev[0];
    trackBytes.push(...varLen(delta));
    for(let i=1;i<ev.length;i++)trackBytes.push(ev[i]);
  });

  const header=[...strBytes('MThd'),...int32(6),...int16(0),...int16(1),...int16(ticksPerBeat)];
  const track=[...strBytes('MTrk'),...int32(trackBytes.length),...trackBytes];
  return new Uint8Array([...header,...track]);
}

