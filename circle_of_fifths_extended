// ── EXPORT: WAV ───────────────────────────────────────────────────────────
document.getElementById('exp-wav').addEventListener('click',async()=>{
  if(!progression.length)return;
  const statusEl=document.getElementById('export-status');
  statusEl.textContent='Rendering audio…';
  const bpm=+document.getElementById('prog-bpm').value;
  const beatDur=60/bpm;
  const chordDur=beatDur*2;
  const totalDur=progression.length*chordDur+0.5;
  const sr=44100;
  const offCtx=new OfflineAudioContext(1,Math.ceil(sr*totalDur),sr);
  const voicings=computeVoicings();

  progression.forEach((p,i)=>{
    const v=voicings[i];
    const r=rootStr(p.chord);
    const rootFreq=NF[r]||261.63;
    const semis=v?v.semis:resolveChordSemis(p,progExtLevel);
    const when=i*chordDur;
    const dur=chordDur*0.9;

    semis.forEach((s,j)=>{
      const freq=rootFreq*Math.pow(2,s/12);
      const osc=offCtx.createOscillator();
      const gn=offCtx.createGain();
      osc.type='triangle';
      osc.frequency.value=freq;
      osc.detune.value=j%2?-3:3;
      gn.gain.setValueAtTime(0,when);
      gn.gain.linearRampToValueAtTime(0.18/semis.length,when+0.04);
      gn.gain.setValueAtTime(0.18/semis.length,when+dur*0.6);
      gn.gain.exponentialRampToValueAtTime(0.001,when+dur);
      osc.connect(gn);gn.connect(offCtx.destination);
      osc.start(when+j*0.018);osc.stop(when+dur+0.1);
    });
  });

  try{
    const rendered=await offCtx.startRendering();
    const numSamples=rendered.length;
    const data=rendered.getChannelData(0);

    const buffer=new ArrayBuffer(44+numSamples*2);
    const view=new DataView(buffer);
    function writeStr(off,s){for(let i=0;i<s.length;i++)view.setUint8(off+i,s.charCodeAt(i));}
    writeStr(0,'RIFF');
    view.setUint32(4,36+numSamples*2,true);
    writeStr(8,'WAVE');
    writeStr(12,'fmt ');
    view.setUint32(16,16,true);
    view.setUint16(20,1,true);
    view.setUint16(22,1,true);
    view.setUint32(24,sr,true);
    view.setUint32(28,sr*2,true);
    view.setUint16(32,2,true);
    view.setUint16(34,16,true);
    writeStr(36,'data');
    view.setUint32(40,numSamples*2,true);
    for(let i=0;i<numSamples;i++){
      const s=Math.max(-1,Math.min(1,data[i]));
      view.setInt16(44+i*2,s<0?s*0x8000:s*0x7FFF,true);
    }
    const blob=new Blob([buffer],{type:'audio/wav'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');a.href=url;a.download='progression.wav';a.click();
    URL.revokeObjectURL(url);
    statusEl.textContent='WAV file downloaded!';
  }catch(e){
    statusEl.textContent='Export failed: '+e.message;
  }
  setTimeout(()=>statusEl.textContent='',3000);
});

// ── SHEET MUSIC NOTATION (VexFlow) ─────────────────────────────────────────

function hasVF(){return typeof Vex!=='undefined'&&Vex.Flow;}

// MIDI to VexFlow key conversion
function midiToVex(midi,useFlats){
  const sN=['c','c#','d','d#','e','f','f#','g','g#','a','a#','b'];
  const fN=['c','db','d','eb','e','f','gb','g','ab','a','bb','b'];
  const names=useFlats?fN:sN;
  const oct=Math.floor(midi/12)-1;
  const name=names[midi%12];
  const acc=name.length>1?(name[1]==='#'?'#':'b'):null;
  return{key:name+'/'+oct,acc};
}

function keyUsesFlats(){
  if(selKey===null)return false;
  const sig=DATA[mode].sigs[selKey];
  return sig.includes('♭');
}

// Semi offset from root → MIDI, using the app's root name
function semiToMidi(rootName,semi,baseOct){
  const rpc=RMIDI[rootName]||0;
  return (baseOct+1)*12+rpc+semi; // baseOct=4 → octave 4 starts at MIDI 60
}

