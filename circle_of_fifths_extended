  minor:['m','m7','mMaj7','m9','mMaj9','m11','m13','m6','m6/9','m(add9)','m(add11)','m7♭5'],
  dim:['°','ø7','°7','ø9','ø11','°7♭9'],
  aug:['+','+7','+Maj7','+9','+Maj9','+7♯9'],
};

// ── NOTE NAMES ────────────────────────────────────────────────────────────────
const RMIDI={C:0,'C#':1,Db:1,D:2,'D#':3,Eb:3,E:4,'E#':5,Fb:4,F:5,'F#':6,Gb:6,G:7,'G#':8,Ab:8,A:9,'A#':10,Bb:10,B:11,Cb:11,'B#':0};
const SN=['C','C♯','D','D♯','E','F','F♯','G','G♯','A','A♯','B'];
const FN=['C','D♭','D','E♭','E','F','G♭','G','A♭','A','B♭','B'];
function noteAt(rootName,semi){
  const useFlats=['F','Bb','Eb','Ab','Db','Gb','Cb'].includes(rootName)||/b$/.test(rootName);
  const mi=((RMIDI[rootName]||0)+(semi%12+12))%12;
  return useFlats?FN[mi]:SN[mi];
}

// ── AUDIO ─────────────────────────────────────────────────────────────────────
const NF={C:261.63,'C#':277.18,Db:277.18,D:293.66,'D#':311.13,Eb:311.13,E:329.63,'E#':349.23,Fb:329.63,F:349.23,'F#':369.99,Gb:369.99,G:392.00,'G#':415.30,Ab:415.30,A:440.00,'A#':466.16,Bb:466.16,B:493.88,Cb:493.88,'B#':523.25};
const IVLS={major:[0,4,7,12],minor:[0,3,7,12],dim:[0,3,6,12],aug:[0,4,8,12]};
let timbre='piano',vol=0.6,ac=null,activeOscs=[],seqRunning=false,seqCBs=[];
function getAC(){if(!ac)ac=new(window.AudioContext||window.webkitAudioContext)();if(ac.state==='suspended')ac.resume();return ac;}
function stopAll(){seqRunning=false;seqCBs.forEach(clearTimeout);seqCBs=[];activeOscs.forEach(o=>{try{o.stop();}catch(e){}});activeOscs=[];}
function qualStr(s){s=(s||'').trim();if(s.includes('°'))return'dim';if(s.includes('+'))return'aug';if(/m$/.test(s))return'minor';return'major';}
function rootStr(s){return s.trim().replace(/[°○+]/g,'').replace(/m$/,'').replace(/♭/g,'b').replace(/♯/g,'#');}

function karplusNote(f,w,d,g){const a=getAC(),sr=a.sampleRate,N=Math.max(2,Math.round(sr/f)),tot=Math.ceil(sr*(d+.2)),buf=a.createBuffer(1,tot,sr),dd=buf.getChannelData(0);for(let i=0;i<N;i++)dd[i]=(Math.random()*2-1);const dc=.995-f/20000;for(let i=N;i<tot;i++)dd[i]=dc*.5*(dd[i-N]+dd[i-N+1]);const src=a.createBufferSource(),gn=a.createGain(),fl=a.createBiquadFilter();src.buffer=buf;fl.type='lowpass';fl.frequency.value=4000;gn.gain.setValueAtTime(g*vol,w);gn.gain.setValueAtTime(g*vol,w+d*.7);gn.gain.exponentialRampToValueAtTime(.001,w+d);src.connect(fl);fl.connect(gn);gn.connect(a.destination);src.start(w);src.stop(w+d+.2);activeOscs.push(src);}
function stringsNote(f,w,d,g){const a=getAC(),mg=a.createGain();mg.gain.setValueAtTime(0,w);mg.gain.linearRampToValueAtTime(g*vol*.28,w+.28);mg.gain.setValueAtTime(g*vol*.28,w+d*.75);mg.gain.linearRampToValueAtTime(0,w+d);mg.connect(a.destination);const lfo=a.createOscillator(),lg=a.createGain();lfo.frequency.value=5.2;lg.gain.value=f*.0045;lfo.connect(lg);lfo.start(w+.15);lfo.stop(w+d+.1);[-8,0,8].forEach(dt=>{const osc=a.createOscillator(),gn=a.createGain(),lp=a.createBiquadFilter();osc.type='sawtooth';osc.frequency.value=f;osc.detune.value=dt;lp.type='lowpass';lp.frequency.value=2400;lp.Q.value=.5;lg.connect(osc.frequency);gn.gain.value=.33;osc.connect(lp);lp.connect(gn);gn.connect(mg);osc.start(w);osc.stop(w+d+.1);activeOscs.push(osc);});activeOscs.push(lfo);}
function oscNote(f,w,d,g,t){const a=getAC(),osc=a.createOscillator(),mg=a.createGain();osc.type=t;osc.frequency.value=f;osc.detune.value=2;mg.gain.setValueAtTime(0,w);mg.gain.linearRampToValueAtTime(g*vol*.42,w+.035);mg.gain.setValueAtTime(g*vol*.42,w+d*.5);mg.gain.exponentialRampToValueAtTime(.001,w+d);osc.connect(mg);mg.connect(a.destination);osc.start(w);osc.stop(w+d+.05);activeOscs.push(osc);}
function playNoteAt(f,w,d=.7,g=1){if(timbre==='guitar')karplusNote(f,w,Math.max(d,1.2),g);else if(timbre==='strings')stringsNote(f,w,Math.max(d,1.4),g);else oscNote(f,w,d,g,{piano:'triangle',soft:'sine',organ:'sawtooth'}[timbre]||'triangle');}

function playChordAt(chord,w,d=2.1){
  const a=getAC(),q=qualStr(chord),r=rootStr(chord),rf=NF[r]||261.63,sm=IVLS[q]||IVLS.major;
  if(timbre==='guitar'){sm.forEach((s,i)=>karplusNote(rf*Math.pow(2,s/12),w+i*.04,d*.95,i===3?.55:.85));}
  else if(timbre==='strings'){sm.forEach((s,i)=>stringsNote(rf*Math.pow(2,s/12),w,d,i===3?.5:.9));}
  else{const t={piano:'triangle',soft:'sine',organ:'sawtooth'}[timbre]||'triangle',mg=a.createGain();mg.gain.setValueAtTime(0,w);mg.gain.linearRampToValueAtTime(vol*.32,w+.05);mg.gain.setValueAtTime(vol*.32,w+d*.4);mg.gain.exponentialRampToValueAtTime(.001,w+d);mg.connect(a.destination);sm.forEach((s,i)=>{const osc=a.createOscillator(),g=a.createGain();osc.type=t;osc.frequency.value=rf*Math.pow(2,s/12);osc.detune.value=i%2?-3:3;g.gain.value=i===3?.5:1;osc.connect(g);g.connect(mg);osc.start(w+i*.018);osc.stop(w+d+.1);activeOscs.push(osc);});}
}

function playExtChord(rf,semis,d=2.4,when){
  const a=getAC(),w=when||a.currentTime;
  if(timbre==='guitar'){semis.forEach((s,i)=>karplusNote(rf*Math.pow(2,s/12),w+i*.04,d*.95,i===0?.9:.75));}
  else if(timbre==='strings'){semis.forEach(s=>stringsNote(rf*Math.pow(2,s/12),w,d,.7));}
  else{const t={piano:'triangle',soft:'sine',organ:'sawtooth'}[timbre]||'triangle',mg=a.createGain();mg.gain.setValueAtTime(0,w);mg.gain.linearRampToValueAtTime(vol*.26,w+.06);mg.gain.setValueAtTime(vol*.26,w+d*.42);mg.gain.exponentialRampToValueAtTime(.001,w+d);mg.connect(a.destination);semis.forEach((s,i)=>{const osc=a.createOscillator(),g=a.createGain();osc.type=t;osc.frequency.value=rf*Math.pow(2,s/12);osc.detune.value=i%2?-3:3;g.gain.value=i===0?.9:.65;osc.connect(g);g.connect(mg);osc.start(w+i*.02);osc.stop(w+d+.1);activeOscs.push(osc);});}
}

// ── INVERSION ENGINE ──────────────────────────────────────────────────────────
function getInvSemis(semis,inv){
  if(inv===0)return semis.slice();
  const n=semis.length,result=[];
  for(let i=0;i<n;i++){const idx=(inv+i)%n;let s=semis[idx];if(i>0){while(s<=result[result.length-1])s+=12;}result.push(s);}
  return result.map(s=>s-12); // drop bass below root
}

// ── CHORD EXPLORER STATE ──────────────────────────────────────────────────────
let exState={root:'C',rootFreq:261.63,quality:'major',extIdx:0,inv:0,label:''};

function openExplorer(chordName,label){
  const q=qualStr(chordName),r=rootStr(chordName);
  exState={root:r,rootFreq:NF[r]||261.63,quality:q,extIdx:0,inv:0,label:label||chordName};
  renderExplorer();
  const el=document.getElementById('expl');
  el.style.display='flex';
  setTimeout(()=>el.scrollIntoView({behavior:'smooth',block:'nearest'}),50);
}

function renderExplorer(){
  const{root,rootFreq,quality,extIdx,inv,label}=exState;
  const defs=EXT_DEFS[quality]||EXT_DEFS.major;
  const suffs=EXT_SUFFIX[quality]||EXT_SUFFIX.major;
  const safeExt=Math.min(extIdx,defs.length-1);
  const def=defs[safeExt];
  const maxInv=Math.min(def.semis.length-1,3);
  const safeInv=Math.min(inv,maxInv);
  exState.extIdx=safeExt;exState.inv=safeInv;

  const invSemis=getInvSemis(def.semis,safeInv);
  const displayRoot=root.replace('#','♯').replace('b','♭');
  const suff=suffs[safeExt]||'';

  // Bass note for slash notation
  const bassOrig=safeInv>0?def.semis[safeInv]:null;
  const bassName=bassOrig!==null?noteAt(root,bassOrig%12):null;
  const slashStr=bassName&&safeInv>0?' / '+bassName:'';

  document.getElementById('expl-cname').textContent=displayRoot+suff;
  document.getElementById('expl-slash').textContent=slashStr;
  document.getElementById('expl-source').textContent='from: '+label;

  // Extension chips — with separator between standard and jazz voicings
  const ec=document.getElementById('expl-ext');ec.innerHTML='';
  const jazzStart={major:9,minor:7,dim:3,aug:3}[quality]||999;
  defs.forEach((d,i)=>{
    if(i===jazzStart){const sep=document.createElement('span');sep.style.cssText='width:1px;height:20px;background:#3a3a4a;margin:0 2px;align-self:center';ec.appendChild(sep);}
    const b=document.createElement('button');b.className='ext-chip'+(i===safeExt?' on':'');b.textContent=d.label;b.onclick=()=>{exState.extIdx=i;exState.inv=0;renderExplorer();};ec.appendChild(b);
  });

  // Inversion buttons
  const ic=document.getElementById('expl-inv');ic.innerHTML='';
  const invNames=['Root pos.','1st inv.','2nd inv.','3rd inv.'];
  for(let i=0;i<=maxInv;i++){const b=document.createElement('button');b.className='inv-btn'+(i===safeInv?' on':'');b.textContent=invNames[i];b.onclick=()=>{exState.inv=i;renderExplorer();};ic.appendChild(b);}

  // Chord tone pills
  const np=document.getElementById('expl-notes');np.innerHTML='';
  invSemis.forEach((s,i)=>{
    const origI=(safeInv+i)%def.semis.length;
    const iv=def.ivl[origI];
    const pClass=def.semis[origI]%12;
    const noteName=noteAt(root,pClass);
    const isBass=i===0&&safeInv>0;
    const pill=document.createElement('div');
    pill.className='expl-note'+(isBass?' bass':'');
    pill.innerHTML=`<span class="en-iv">${iv}${isBass?' ♩':''}</span><span class="en-nt">${noteName}</span>`;
    const freq=rootFreq*Math.pow(2,s/12);
    pill.onclick=()=>{
      stopAll();playNoteAt(freq,getAC().currentTime,1.0);
      document.querySelectorAll('.expl-note').forEach(b=>b.classList.remove('lit'));
      pill.classList.add('lit');setTimeout(()=>pill.classList.remove('lit'),900);
    };
    np.appendChild(pill);
  });

  // Voice info
  const noteCount=def.semis.length;
  const invLabel=safeInv===0?'root position':invNames[safeInv];
  document.getElementById('expl-voice-info').textContent=`${noteCount} tones · ${invLabel}`;

  document.getElementById('expl-play').onclick=()=>{stopAll();playExtChord(rootFreq,invSemis);};
  // Update piano from explorer
  if(typeof pianoFromExplorer==='function'){pianoFromExplorer();showPiano();}
  if(typeof renderExplNotation==='function'&&notationVisible)renderExplNotation();
}

// ── CANVAS ────────────────────────────────────────────────────────────────────
const cv=document.getElementById('cv'),ctx=cv.getContext('2d');
const SZ=Math.min(window.innerWidth-16,540);
cv.width=SZ*devicePixelRatio;cv.height=SZ*devicePixelRatio;cv.style.width=SZ+'px';cv.style.height=SZ+'px';ctx.scale(devicePixelRatio,devicePixelRatio);
const CX=SZ/2,CY=SZ/2;
const QC={major:{bg:'#3B6FA0',fg:'#C8E0F8'},minor:{bg:'#5B4FA0',fg:'#D8D4F8'},aug:{bg:'#A06020',fg:'#F8DEAD'},dim:{bg:'#3A7A3A',fg:'#C8EAC8'}};
const INNER=22,OUTER=SZ/2-4,KN_W=Math.floor((OUTER-INNER)*.14),SIG_W=Math.floor((OUTER-INNER)*.07);
const CH_W=Math.floor((OUTER-INNER-KN_W-SIG_W)/7),R=[];let rCur=INNER;
for(let i=0;i<7;i++){R.push([rCur,rCur+CH_W]);rCur+=CH_W;}R.push([rCur,rCur+SIG_W]);rCur+=SIG_W;R.push([rCur,rCur+KN_W]);
const FONT='system-ui,-apple-system,sans-serif';
let mode='natural',hov=null,activeArc=null,selKey=null,selMode=0,playTimer=null;
let notationVisible=false;

function drawArc(ir,or,sa,ea,fill){ctx.beginPath();ctx.arc(0,0,or,sa,ea);ctx.arc(0,0,ir,ea,sa,true);ctx.closePath();ctx.fillStyle=fill;ctx.fill();}
function strokeArc(ir,or,sa,ea){ctx.beginPath();ctx.arc(0,0,or,sa,ea);ctx.arc(0,0,ir,ea,sa,true);ctx.closePath();ctx.strokeStyle='rgba(0,0,0,0.35)';ctx.lineWidth=0.7;ctx.stroke();}
function putText(txt,ang,r,fs,col,bold){const tx=r*Math.cos(ang),ty=r*Math.sin(ang);ctx.save();ctx.translate(tx,ty);let rot=ang+Math.PI/2;if(Math.cos(ang)<-0.01)rot+=Math.PI;ctx.rotate(rot);ctx.font=`${bold?'600':'400'} ${fs}px ${FONT}`;ctx.fillStyle=col;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(txt,0,0);ctx.restore();}

function draw(){
  ctx.clearRect(0,0,SZ,SZ);ctx.save();ctx.translate(CX,CY);const md=DATA[mode];
  for(let ki=0;ki<12;ki++){
    const mid=-Math.PI/2+ki*(Math.PI/6),sa=mid-Math.PI/12+.005,ea=mid+Math.PI/12-.005,isSel=selKey===ki;
    for(let ri=0;ri<7;ri++){const chord=md.rows[ki][ri],q=qualStr(chord),col=QC[q],[ir,or]=R[ri];drawArc(ir,or,sa,ea,col.bg);if(isSel)drawArc(ir,or,sa,ea,'rgba(255,255,255,0.08)');if(hov&&hov.ki===ki&&hov.ri===ri)drawArc(ir,or,sa,ea,'rgba(255,255,255,0.12)');if(activeArc&&activeArc.ki===ki&&activeArc.ri===ri)drawArc(ir,or,sa,ea,'rgba(255,255,255,0.24)');strokeArc(ir,or,sa,ea);const bw=or-ir,fs=Math.min(bw*.42,12);if(fs>4)putText(chord,mid,(ir+or)/2,fs,col.fg,ri===0);}
    {const[ir,or]=R[7];drawArc(ir,or,sa,ea,isSel?'#38384A':'#2A2A38');strokeArc(ir,or,sa,ea);const sig=md.sigs[ki];if(sig)putText(sig,mid,(ir+or)/2,7,'#9090B8',false);}
    {const[ir,or]=R[8];drawArc(ir,or,sa,ea,isSel?'#3A3464':'#1E1E2E');if(hov&&hov.ki===ki&&hov.ri===8)drawArc(ir,or,sa,ea,'rgba(255,255,255,0.1)');strokeArc(ir,or,sa,ea);const fs=Math.min((or-ir)*.55,14);putText(md.keys[ki],mid,(ir+or)/2,fs,isSel?'#C8C4FF':'#E8E4FF',true);}
  }
  for(let ri=0;ri<8;ri++){ctx.beginPath();ctx.arc(0,0,R[ri][1],0,Math.PI*2);ctx.strokeStyle='rgba(255,255,255,0.05)';ctx.lineWidth=1;ctx.stroke();}
  ctx.beginPath();ctx.arc(0,0,INNER,0,Math.PI*2);ctx.fillStyle='#13131F';ctx.fill();ctx.strokeStyle='rgba(255,255,255,0.1)';ctx.lineWidth=1;ctx.stroke();
  ctx.font=`400 ${Math.max(6,INNER*.28)}px ${FONT}`;ctx.fillStyle='#7070A0';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('Circle of',0,-INNER*.2);ctx.fillText('Fifths',0,INNER*.2);ctx.restore();
}

function getHit(ex,ey){const rect=cv.getBoundingClientRect(),sx=SZ/rect.width,sy=SZ/rect.height,x=(ex-rect.left)*sx-CX,y=(ey-rect.top)*sy-CY,dist=Math.sqrt(x*x+y*y);let ri=-1;for(let i=0;i<R.length;i++){if(dist>=R[i][0]&&dist<R[i][1]){ri=i;break;}}if(ri<0)return null;const ang=((Math.atan2(y,x)*180/Math.PI)+360+90)%360;return{ki:Math.floor(ang/30)%12,ri};}

// ── PANEL BUILDERS ────────────────────────────────────────────────────────────
const QL={major:'major',minor:'minor',aug:'augmented',dim:'diminished'};
function litSingle(el,dur){el.classList.add('lit');setTimeout(()=>el.classList.remove('lit'),dur);}

function makeChordBtn(chord,deg,cid){
  const q=qualStr(chord),btn=document.createElement('div');
  btn.className=`chord-btn ${q}`;
  btn.innerHTML=`<span class="cb-deg">${deg}</span><span class="cb-nm">${chord}</span><span class="cb-ql">${QL[q]}</span>`;
  btn.addEventListener('click',()=>{
    stopAll();playChordAt(chord,getAC().currentTime);
    document.querySelectorAll('#'+cid+' .chord-btn').forEach(b=>b.classList.remove('lit'));
    litSingle(btn,2200);
    document.getElementById('cinfo').textContent=`${chord} · ${deg}`;
    openExplorer(chord,deg+' of '+DATA[mode].keys[selKey||0]+' ('+chord+')');
    // Piano + Progression
    if(typeof pianoFromChord==='function'){pianoFromChord(chord);showPiano();}
    if(typeof addToProgression==='function'){addToProgression(chord,deg);}
  });
  return btn;
}

function buildParentChordStrip(ki){
  const md=DATA[mode];document.getElementById('chord-title').textContent=`${md.keys[ki]} ${md.label} — Chord Scale`;
  const cs=document.getElementById('chord-strip');cs.innerHTML='';
  md.rows[ki].forEach((chord,i)=>cs.appendChild(makeChordBtn(chord,md.degs[i],'chord-strip')));
}
function getModeChords(ki,mi){const pc=DATA[mode].rows[ki],arr=[];for(let i=0;i<7;i++)arr.push(pc[(mi+i)%7]);return arr;}
function getModeRootFreq(ki,mi){const note=DATA[mode].scaleNotes[ki][mi%7];return NF[note.replace(/♭/g,'b').replace(/♯/g,'#')]||261.63;}
function getModeNotes(ki,mi){const sn=DATA[mode].scaleNotes[ki],arr=[];for(let i=0;i<7;i++)arr.push(sn[(mi+i)%7]);arr.push(sn[mi%7]);return arr;}

function buildModeChordStrip(ki,mi){
  const mdata=MDATA[mode],chords=getModeChords(ki,mi),degs=mdata.degs[mi];
  const cs=document.getElementById('mode-chord-strip');cs.innerHTML='';
  chords.forEach((chord,i)=>cs.appendChild(makeChordBtn(chord,degs[i],'mode-chord-strip')));
}
function buildModeStrip(ki){
  const md=DATA[mode],mdata=MDATA[mode];
  document.getElementById('modes-sec-title').textContent=`${md.keys[ki]} ${md.label} — Modes`;
  const ms=document.getElementById('mode-strip');ms.innerHTML='';
  mdata.names.forEach((name,mi)=>{
    const rn=DATA[mode].scaleNotes[ki][mi%7];
    const pill=document.createElement('div');pill.className='mode-pill'+(mi===selMode?' on':'');
    pill.innerHTML=`<span class="mp-dg">${DATA[mode].degs[mi]}</span><span class="mp-nm">${name.replace(' ','<br>')}</span><span class="mp-rt">${rn}</span>`;
    pill.addEventListener('click',()=>{selMode=mi;buildModeStrip(ki);buildModeDetail(ki);if(typeof rebuildProgChords==='function')rebuildProgChords();if(typeof renderExtraScale==='function'){buildExtraScaleTabs();renderExtraScale();}});
    ms.appendChild(pill);
  });
}
function buildModeDetail(ki){
  const md=DATA[mode],mdata=MDATA[mode],mi=selMode;
  const mRootNote=md.scaleNotes[ki][mi%7];
  document.getElementById('mode-name').textContent=mRootNote+' '+mdata.names[mi];
  document.getElementById('mode-root-lbl').textContent=md.degs[mi]+' of '+md.keys[ki];
  const ivEl=document.getElementById('mode-intervals');ivEl.innerHTML='';
  mdata.ivs[mi].forEach(iv=>{const t=document.createElement('span');t.className='int-tag'+(iv==='R'?' root':'');t.textContent=iv;ivEl.appendChild(t);});
  buildModeChordStrip(ki,mi);
  const notes=getModeNotes(ki,mi),ivs=mdata.ivs[mi],rf=getModeRootFreq(ki,mi),semis=mdata.semis[mi];
  const ns=document.getElementById('mode-note-strip');ns.innerHTML='';
  notes.forEach((note,i)=>{
    const freq=rf*Math.pow(2,semis[i]/12);
    const btn=document.createElement('div');btn.className='note-btn';
    btn.innerHTML=`<span class="nb-iv">${ivs[i]||'8'}</span><span class="nb-nt">${note}</span>`;
    btn.addEventListener('click',()=>{stopAll();playNoteAt(freq,getAC().currentTime,.9);document.querySelectorAll('.note-btn').forEach(b=>b.classList.remove('lit'));litSingle(btn,900);document.getElementById('cinfo').textContent=`${note} · ${ivs[i]||'8'} of ${mRootNote} ${mdata.names[mi]}`;});
    ns.appendChild(btn);
  });
  // Update piano with mode scale
  if(typeof pianoFromScale==='function'){pianoFromScale(ki,mi);showPiano();}
}
function buildPanel(ki){buildParentChordStrip(ki);buildModeStrip(ki);buildModeDetail(ki);document.getElementById('bottom').style.display='flex';if(typeof buildExtraScaleTabs==='function'){buildExtraScaleTabs();renderExtraScale();}if(typeof updateAllNotation==='function')updateAllNotation();}

// ── PLAY ALL ──────────────────────────────────────────────────────────────────
function seqPlay(items,playFn,btnSel,sp){
  stopAll();seqRunning=true;const a=getAC();
  items.forEach((item,i)=>{
    playFn(item,a.currentTime+i*sp,sp*.85);
    seqCBs.push(setTimeout(()=>{
      if(!seqRunning)return;
      document.querySelectorAll(btnSel).forEach((b,j)=>b.classList.toggle('lit',j===i));
      if(i===items.length-1)seqCBs.push(setTimeout(()=>document.querySelectorAll(btnSel).forEach(b=>b.classList.remove('lit')),1200));
    },i*sp*1000));
  });
}
